# ============================================
# AliağaAI - Environment Variables Template
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ── Database (PostgreSQL + pgvector) ─────────────────
DATABASE_URL=postgresql+asyncpg://aliagai:aliagai_secret@localhost:5432/aliagai_db

# ── AI - Groq (ücretsiz tier) ───────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embedding Model ─────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ── Environment ──────────────────────────────────────
ENV=development
DEBUG=true
# RAG tuning
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.85
RAG_VECTOR_CANDIDATES=30
RAG_LEXICAL_CANDIDATES=30
RAG_VECTOR_WEIGHT=0.75
RAG_LEXICAL_WEIGHT=0.25
RAG_RERANK_ENABLED=true
RAG_RERANK_TOP_N=12
RAG_QUERY_EXPANSION_ENABLED=true
RAG_MAX_QUERY_VARIANTS=3
RAG_SHORT_QUERY_MIN_SIMILARITY=0.80
RAG_MEDIUM_QUERY_MIN_SIMILARITY=0.83
RAG_LEXICAL_RESCUE_SCORE=0.65
RAG_MIN_EVIDENCE_CONFIDENCE=0.72
RAG_MIN_EVIDENCE_CHUNKS=1
RAG_ENABLE_CONTROLLED_AUGMENTATION=true
RAG_ENABLE_MODEL_ONLY_FALLBACK=true
RAG_MODEL_ONLY_BASE_CONFIDENCE=0.35
RAG_AUGMENTATION_MIN_EVIDENCE=0.45
RAG_PARALLEL_RETRIEVAL_ENABLED=true
RAG_SKIP_VECTOR_WHEN_SQL_HIT=true
PERSONA_ENABLED=true
PERSONA_TEMPERATURE=0.35

# Embedding runtime
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=16

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=120
CHUNK_MIN_LENGTH=80
EMBEDDING_RETRY_COOLDOWN_SEC=60

# Docker Compose defaults
POSTGRES_USER=aliagai
POSTGRES_PASSWORD=aliagai_secret
POSTGRES_DB=aliagai_db

# Frontend (Expo web)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Startup behavior
STARTUP_BACKGROUND_JOBS_ENABLED=true
STARTUP_EMBEDDING_WARMUP_ENABLED=true
