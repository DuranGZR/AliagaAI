# ============================================
# AliağaAI - Environment Variables Template
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ── Database (PostgreSQL + pgvector) ─────────────────
DATABASE_URL=postgresql+asyncpg://aliagai:aliagai_secret@localhost:5432/aliagai_db

# ── AI - Groq (ücretsiz tier) ───────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embedding Model ─────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ── Environment ──────────────────────────────────────
ENV=development
DEBUG=true
